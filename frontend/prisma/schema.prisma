datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- NextAuth Models ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom Carwash relations
  memberships   Membership[]
  transactions  Transaction[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- SaaS B2B Models ---

model Business {
  id               String   @id @default(cuid())
  name             String   @default("Mi Franquicia")
  subscriptionEnd  DateTime?
  isTrial          Boolean  @default(true)
  
  memberships      Membership[]
  locations        Location[]
}

model Membership {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  role       Role     @default(WORKER)
  
  locationId     String?
  commissionType CommissionType @default(NONE)
  commissionValue Float @default(0)

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location   Location? @relation(fields: [locationId], references: [id])

  @@unique([userId, businessId])
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  WORKER
}

enum CommissionType {
  PER_CAR
  PERCENTAGE_TOTAL
  FIXED_AMOUNT
  NONE
}

model Location {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  
  whatsappConnected  Boolean  @default(false)
  whatsappMessage    String?

  memberships        Membership[]
  products           Product[]
  transactions       Transaction[]
  expenses           Expense[]
}

model Product {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  category    Category
  price       Float
  stock       Int?
  
  items       TransactionItem[]
}

enum Category {
  LAVADO
  SERVICIO_ADICIONAL
  PRODUCTO_AUTO
  SNACK
}

model Transaction {
  id                 String   @id @default(cuid())
  locationId         String
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  workerId           String
  worker             User     @relation(fields: [workerId], references: [id])
  customerName       String?
  customerPhone      String?
  customerPlate      String?
  vehicleType        String?
  paymentMethod      PaymentMethod
  totalAmount        Float
  status             Status   @default(COMPLETED)
  cancellationReason String?
  createdAt          DateTime @default(now())

  items              TransactionItem[]
}

enum PaymentMethod {
  CASH
  YAPE
  PLIN
  CARD
}

enum Status {
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PENDING_CANCELLATION
}

model TransactionItem {
  id            String   @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int @default(1)
  priceAtSale   Float
}

model Expense {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  workerId    String
  amount      Float
  concept     String
  createdAt   DateTime @default(now())
}

model WhatsappAuth {
  id         String   @id @default(cuid())
  locationId String
  key        String   
  value      String   @db.Text
  
  @@unique([locationId, key])
}
